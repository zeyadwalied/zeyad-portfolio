                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ action: 'get_user_info' })
        })
        .then(response => response.json())
        .then(userInfo => {
            if (userInfo) {
                aboutText.innerHTML = userInfo.aboutText || "";
                birthday.textContent = userInfo.birthday || "";
                phone.textContent = userInfo.phone || "";
                city.textContent = userInfo.city || "";
                ladderArrangement.textContent = userInfo.ladderArrangement || "";
                age.textContent = userInfo.age || "";
                AboutEmailDisplay.textContent = userInfo.AboutEmail || "";
                freelance.textContent = userInfo.freelance || "";
                jobTitle.textContent = userInfo.jobTitle || "";
                aboutImage.src = userInfo.imageSrc || "";
                AboutEmail.value = userInfo.AboutEmail || "";

                document.getElementById("aboutText").value = aboutText.innerHTML.replace(/<br>/g, "\n").trim();
                document.getElementById("birthday").value = birthday.textContent.trim();
                document.getElementById("phone").value = phone.textContent.trim();
                document.getElementById("city").value = city.textContent.trim();
                document.getElementById("ladderArrangement").value = ladderArrangement.textContent.trim();
                document.getElementById("age").value = age.textContent.trim();
                document.getElementById("freelance").value = freelance.textContent.trim();
                document.querySelector("#jobTitle").value = jobTitle.textContent.trim();
                AboutEmail.value = userInfo.AboutEmail || "";
            }
        })
        .catch(error => {
            console.error('Error:', error);
        });
    }

    loadStoredData();

    function showAboutForm() {
        aboutForm.classList.remove("hidden");
        document.getElementById("aboutText").value = aboutText.innerHTML.replace(/<br>/g, "\n").trim();
        document.getElementById("birthday").value = birthday.textContent.trim();
        document.getElementById("phone").value = phone.textContent.trim();
        document.getElementById("city").value = city.textContent.trim();
        document.getElementById("ladderArrangement").value = ladderArrangement.textContent.trim();
        document.getElementById("age").value = age.textContent.trim();
        document.getElementById("freelance").value = freelance.textContent.trim();
        document.querySelector("#jobTitle").value = jobTitle.textContent.trim();
        AboutEmail.value = AboutEmailDisplay.textContent.trim();
        fileInput.style.display = 'none';
        document.getElementById('admin-controls').style.display='none';
    }

    aboutForm.addEventListener("submit", function (event) {
        event.preventDefault();
        const newAboutText = document.getElementById("aboutText").value.trim();
        const newBirthday = document.getElementById("birthday").value.trim();
        const newPhone = document.getElementById("phone").value.trim();
        const newCity = document.getElementById("city").value.trim();
        const newLadderArrangement = document.getElementById("ladderArrangement").value.trim();
        const newAge = document.getElementById("age").value.trim();
        const newAboutEmail = AboutEmail.value.trim();
        const newFreelance = document.getElementById("freelance").value.trim();
        const newJobTitle = document.getElementById("jobTitle").value.trim();

        const newAboutTextFormatted = newAboutText.split("\n");
        aboutText.innerHTML = newAboutTextFormatted[0];
        if (newAboutTextFormatted.length > 1) {
            aboutText.innerHTML += "<br>" + newAboutTextFormatted.slice(1).join("<br>");
        }

        birthday.textContent = newBirthday;
        phone.textContent = newPhone;
        city.textContent = newCity;
        ladderArrangement.textContent = newLadderArrangement;
        age.textContent = newAge;
        AboutEmailDisplay.textContent = newAboutEmail;
        freelance.textContent = newFreelance;
        jobTitle.textContent = newJobTitle;

        const file = fileInput.files[0];
        const imageUrlInput = imageInput.value.trim();

        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                aboutImage.src = e.target.result;
                uploadStatus.textContent = "Upload Done";
                imageInput.value = "";

                fetch('http://localhost/backend.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        action: 'save_user_info',
                        aboutText: aboutText.innerHTML,
                        birthday: newBirthday,
                        phone: newPhone,
                        city: newCity,
                        ladderArrangement: newLadderArrangement,
                        age: newAge,
                        AboutEmail: newAboutEmail,
                        freelance: newFreelance,
                        jobTitle: newJobTitle,
                        imageSrc: aboutImage.src
                    })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        endMessage.style.display = 'block';
                        endMessage.textContent = "Update Done";
                        setTimeout(() => {
                            endMessage.classList.add('fadeOut');
                            uploadStatus.classList.add('fadeOut');
                            setTimeout(() => {
                                endMessage.style.display = 'none';
                                uploadStatus.textContent = "";
                                endMessage.classList.remove('fadeOut');
                                uploadStatus.classList.remove('fadeOut');
                            }, 1000);
                        }, 1000);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                });
            };
            reader.readAsDataURL(file);
        } else if (imageUrlInput) {
            aboutImage.src = imageUrlInput;
            uploadStatus.textContent = "Update by link Done";

            fetch('http://localhost/backend.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    action: 'save_user_info',
                    aboutText: aboutText.innerHTML,
                    birthday: newBirthday,
                    phone: newPhone,
                    city: newCity,
                    ladderArrangement: newLadderArrangement,
                    age: newAge,
                    AboutEmail: newAboutEmail,
                    freelance: newFreelance,
                    jobTitle: newJobTitle,
                    imageSrc: aboutImage.src
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    endMessage.style.display = 'block';
                    endMessage.textContent = "Update Done";
                    setTimeout(() => {
                        endMessage.classList.add('fadeOut');
                        uploadStatus.classList.add('fadeOut');
                        setTimeout(() => {
                            endMessage.style.display = 'none';
                            uploadStatus.textContent = "";
                            endMessage.classList.remove('fadeOut');
                            uploadStatus.classList.remove('fadeOut');
                        }, 1000);
                    }, 1000);
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        } else {
            fetch('http://localhost/backend.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    action: 'save_user_info',
                    aboutText: aboutText.innerHTML,
                    birthday: newBirthday,
                    phone: newPhone,
                    city: newCity,
                    ladderArrangement: newLadderArrangement,
                    age: newAge,
                    AboutEmail: newAboutEmail,
                    freelance: newFreelance,
                    jobTitle: newJobTitle,
                    imageSrc: aboutImage.src
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    endMessage.style.display = 'block';
                    endMessage.textContent = "Update Done";
                    setTimeout(() => {
                        endMessage.classList.add('fadeOut');
                        uploadStatus.classList.add('fadeOut');
                        setTimeout(() => {
                            endMessage.style.display = 'none';
                            uploadStatus.textContent = "";
                            endMessage.classList.remove('fadeOut');
                            uploadStatus.classList.remove('fadeOut');
                        }, 1000);
                    }, 1000);
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        }
    });

    const aboutFormBtn = document.getElementById("about-formBtn");
    if (aboutFormBtn) {
        aboutFormBtn.addEventListener("click", showAboutForm);
    }

    const closeAboutFormBtn = document.querySelector(".Close-About-Form");
    if (closeAboutFormBtn) {
        closeAboutFormBtn.addEventListener("click", () => {
            aboutForm.classList.add("hidden");
            hideAboutContent();
            document.getElementById('admin-controls').style.display = 'flex';
        });
    }
});

document.addEventListener("DOMContentLoaded", function () {
    loadFormData();
    updatePageData();

    const backgroundUpload = document.getElementById('backgroundUpload');
    const backgroundLink = document.getElementById('backgroundLink');

    backgroundUpload.addEventListener('change', function (event) {
        const file = event.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                fetch('http://localhost/backend.php', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ action: 'save_background', backgroundImageUrl: e.target.result })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.status === 'success') {
                        backgroundLink.value = '';
                        updateBackground();
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                });
            };
            reader.readAsDataURL(file);
        }
    });

    backgroundLink.addEventListener('change', function () {
        const link = this.value;
        if (link) {
            fetch('http://localhost/backend.php', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ action: 'save_background', backgroundImageUrl: link })
            })
            .then(response => response.json())
            .then(data => {
                if (data.status === 'success') {
                    updateBackground();
                }
            })
            .catch(error => {
                console.error('Error:', error);
            });
        }
    });
});

document.addEventListener('DOMContentLoaded', function() {
    updatePageData();
});

document.getElementById('containerBtnForm').addEventListener('click', function() {
    document.getElementById('formContainer').style.display = 'block';
    document.querySelector('.titlestorm').style.display = 'block';
    document.querySelector('.h').style.display = 'block';
    document.querySelector('.h').style.fontSize = '10px';
    document.querySelector('.titlestorm').style.fontSize = '20px';
    document.querySelector('.h').style.position = 'relative';
    document.querySelector('.h').style.bottom = '1px';
    document.querySelector('.h').style.left = '10px';
    document.querySelector('.social-links').style.display = 'block';
    navbar.style.position = 'absolute';
    navbar.style.top = '10px';
    navbar.style.right = '0';
    loadFormData();
    document.getElementById('admin-controls').style.display='none';
});

function clearCon(){
    resetStyles();
    document.getElementById('formContainer').style.display = 'none';
    navbar.style.position = 'absolute';
    navbar.style.top = '10px';
    navbar.style.left = '0';
    document.querySelector('.h').style.display='none';
    document.querySelector('.social-links').style.display ='none';
}

document.querySelector('.Closebtn3').addEventListener('click', function() {
    clearCon();
    document.getElementById('admin-controls').style.display='flex';
});

function loadFormData() {
    fetch('http://localhost/backend.php', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ action: 'get_contact_info' })
    })
    .then(response => response.json())
    .then(contactInfo => {
        const name = contactInfo.name || '';
        const role = contactInfo.role || '';
        const projects = contactInfo.projects || '';
        const email = contactInfo.email || '';
        const facebook = contactInfo.facebook || '';
        const instagram = contactInfo.instagram || '';
        const github = contactInfo.github || '';
        const backgroundImageUrl = contactInfo.backgroundImageUrl || '';
        const introText = contactInfo.introText || 'I\'m a';
        const cv = contactInfo.cv || '';

        document.getElementById('name').value = name;
        document.getElementById('spanFr').value = role;
        document.getElementById('projects').value = projects;
        document.getElementById('email').value = email;
        document.getElementById('facebook').value = facebook;
        document.getElementById('instagram').value = instagram;
        document.getElementById('github').value = github;
        document.getElementById('introText').value = introText;
        document.getElementById('CV').value = cv;

        const backgroundImageUrlElement = document.getElementById('backgroundLink');
        if (backgroundImageUrlElement) {
            if (backgroundImageUrl && isOnlineLink(backgroundImageUrl)) {
                backgroundImageUrlElement.value = backgroundImageUrl;
            } else {
                backgroundImageUrlElement.value = '';
            }
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function isOnlineLink(url) {
    try {
        const parsedUrl = new URL(url);
        return parsedUrl.protocol === 'http:' || parsedUrl.protocol === 'https:';
    } catch (e) {
        return false;
    }
}

function updateData() {
    const name = document.getElementById('name').value;
    const role = document.getElementById('spanFr').value;
    const projects = document.getElementById('projects').value;
    const email = document.getElementById('email').value;
    const facebook = document.getElementById('facebook').value;
    const instagram = document.getElementById('instagram').value;
    const github = document.getElementById('github').value;
    const introText = document.getElementById('introText').value;
    const cv = document.getElementById('CV').value;

    fetch('http://localhost/backend.php', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            action: 'save_contact_info',
            name,
            role,
            projects,
            email,
            facebook,
            instagram,
            github,
            introText,
            cv
        })
    })
    .then(response => response.json())
    .then(data => {
        if (data.status === 'success') {
            document.querySelector('.titlestorm').textContent = name;

            const spanElement = document.querySelector('.start');
            if (spanElement) {
                if (role) {
                    spanElement.innerHTML = `${introText} <span class="spanFr">${role}</span> ${projects}`;
                    const spanFr = document.querySelector('.spanFr');
                    if (spanFr) {
                        spanFr.style.borderBottom = '2px solid green';
                    }
                } else {
                    spanElement.innerHTML = `${introText} <span class="spanFr"> Add YOUR JOB TITLE </span>  ${projects}`;
                }
            }

            document.querySelector('.social-links ul li\:nth-child(1) a').href = `mailto:${email}?subject=استفسار&body=مرحبًا، أود معرفة المزيد عن ...`;
            document.querySelector('.social-links ul li\:nth-child(2) a').href = facebook;
            document.querySelector('.social-links ul li\:nth-child(3) a').href = instagram;
            document.querySelector('.social-links ul li\:nth-child(4) a').href = github;
            document.querySelector('.social-links ul li\:nth-child(5) a').href = cv;

            updateBackground();
            showUpdatedMessage();
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function updateBackground() {
    fetch('http://localhost/backend.php', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ action: 'get_background' })
    })
    .then(response => response.json())
    .then(backgroundImageUrl => {
        if (backgroundImageUrl) {
            document.body.style.backgroundImage = `url(${backgroundImageUrl})`;
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function resetStyles() {
    document.querySelector('.h').style.fontSize = '';
    document.querySelector('.titlestorm').style.fontSize = '';
    document.querySelector('.h').style.position = '';
    document.querySelector('.h').style.bottom = '';
    document.querySelector('.h').style.left = '';
    document.querySelector('.social-links').style.display = '';
    navbar.style.position = '';
    navbar.style.top = '';
    navbar.style.right = '';
}

function updatePageData() {
    fetch('http://localhost/backend.php', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ action: 'get_contact_info' })
    })
    .then(response => response.json())
    .then(contactInfo => {
        const name = contactInfo.name || '';
        const role = contactInfo.role || '';
        const projects = contactInfo.projects || '';
        const email = contactInfo.email || '';
        const facebook = contactInfo.facebook || '';
        const instagram = contactInfo.instagram || '';
        const github = contactInfo.github || '';
        const backgroundImageUrl = contactInfo.backgroundImageUrl || '';
        const introText = contactInfo.introText || 'I\'m a';
        const cv = contactInfo.cv || '';

        document.querySelector('.titlestorm').textContent = name;

        const spanElement = document.querySelector('.start');
        if (spanElement) {
            if (role) {
                spanElement.innerHTML = `${introText} <span class="spanFr">${role}</span> ${projects}`;
                const spanFr = document.querySelector('.spanFr');
                if (spanFr) {
                    spanFr.style.borderBottom = '2px solid green';
                }
            } else {
                spanElement.innerHTML = `${introText} <span class="spanFr"> add your job here </span> ${projects}`;
            }
        }

        document.querySelector('.social-links ul li\:nth-child(1) a').href = `mailto:${email}?subject=استفسار&body=مرحبًا، أود معرفة المزيد عن ...`;
        document.querySelector('.social-links ul li\:nth-child(2) a').href = facebook;
        document.querySelector('.social-links ul li\:nth-child(3) a').href = instagram;
        document.querySelector('.social-links ul li\:nth-child(4) a').href = github;
        document.querySelector('.social-links ul li\:nth-child(5) a').href = cv;

        if (backgroundImageUrl) {
            document.body.style.backgroundImage = `url(${backgroundImageUrl})`;
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function showUpdatedMessage() {
    document.querySelector('.msgCon').style.display='block';
    setTimeout(() => {
        document.querySelector('.msgCon').style.display='none';
    }, 2000);
}

window.addEventListener('error', function(event) {
    if (event.message && event.message.includes("Failed to load resource")) {
        event.preventDefault();
    }
});

window.addEventListener('error', function(event) {
    if (event.filename && event.filename.includes("play.google.com")) {
        event.preventDefault();
    }
});

window.addEventListener('unhandledrejection', function(event) {
    if (event.reason && event.reason.message.includes("Failed to load resource")) {
        event.preventDefault();
    }
});

function loadData() {
    let xhr = new XMLHttpRequest();
    xhr.open("GET", "http://localhost/backend.php", true);
    xhr.onload = function() {
        if (this.status == 200) {
            document.getElementById("result").innerHTML = this.responseText;
        }
    };
    xhr.send();
}
