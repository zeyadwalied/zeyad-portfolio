const links = document.querySelectorAll('.link a');


links.forEach((link) => {
link.addEventListener('click', (event) => {
event.preventDefault();
const url = link.getAttribute('href');


hideAdminContent();

    // إدارة الانتقال بين الأقسام
    switch (url) {
        case 'index.html':
            resetToHomePage();
            break;
        case '#contact':
            hideAllSections();
            showContactContent();
            break;
        case '#about':
            hideAllSections();
            showAboutContent();
            break;
        case '#personale-projects':
            hideAllSections();
            showPersonaleProjects();
            break;
        default:
            if (url !== '#') window.open(url, '_blank');
    }

    closeSettings();

    // تحديث عنوان الURL دون تحميل صفحة جديدة
    history.pushState(null, '', url);
});
});

