// إضافة مشروع جديد أو تحديث المشروع الحالي في القائمة
projectForm.addEventListener('submit', (event) => {
    event.preventDefault();
    const title = document.getElementById('projectTitle').value;
    const description = document.getElementById('projectDescription').value;
    const youtubeLink = document.getElementById('youtubeLink').value;

    fetch('http://localhost/backend.php', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ action: 'save_project', title, description, youtubeLink })
    })
    .then(response => response.json())
    .then(data => {
        if (data.status === 'success') {
            projectMessage.textContent = 'Project Added!';
            projectMessage.style.color = 'green';
            projectForm.reset();
            resetMessage(projectMessage);
            loadProjectsFromBackend();
            toggleProjectButtons(true);
        } else {
            projectMessage.textContent = 'Failed to add project.';
            projectMessage.style.color = 'red';
        }
    })
    .catch(error => {
        console.error('Error:', error);
    });
});

function createProjectElement(title, description, link) {
    const projectElement = document.createElement('div');
    projectElement.classList.add('col-lg-4', 'col-md-6', 'my-1');

    const isYouTubeLink = link.includes("youtube.com") || link.includes("youtu.be");
    let iframeSrc = link;

    if (isYouTubeLink) {
        if (link.includes("youtube.com/watch?v=")) {
            const videoId = link.split("v=")[1].split("&")[0];
            iframeSrc = `https://www.youtube.com/embed/${videoId}`;
        } else if (link.includes("youtu.be/")) {
            const videoId = link.split("youtu.be/")[1].split("?")[0];
            iframeSrc = `https://www.youtube.com/embed/${videoId}`;
        }
    }

    projectElement.innerHTML = `
        <div class="icon-box rounded">
            <iframe class="w-100 h-100" src="${iframeSrc}" frameborder="0" allowfullscreen></iframe>
            <h4><a href="${link}" target="_blank">${title}</a></h4>
            <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
                <button class="project-update-btn">UPDATE</button>
                <button class="project-delete-btn">DELETE</button>
            </div>
            <p class='prFont'>${description}</p>
        </div>
    `;

    const deleteButton = projectElement.querySelector('.project-delete-btn');
    const updateButton = projectElement.querySelector('.project-update-btn');

    deleteButton.addEventListener('click', () => {
        projectElement.remove();
        loadProjectsFromBackend();
        toggleProjectButtons(true);
    });

    updateButton.addEventListener('click', () => {
        document.getElementById('projectTitle').value = title;
        document.getElementById('projectDescription').value = description;
        document.getElementById('youtubeLink').value = link;
        currentEditProject = projectElement;
    });

    return projectElement;
}

function resetMessage(messageElement) {
    setTimeout(() => {
        messageElement.classList.add('fadeOut');
        setTimeout(() => {
            messageElement.textContent = '';
            messageElement.style.color = '';
            messageElement.classList.remove('fadeOut');
        }, 2000);
    }, 2500);
}

function resetLoginForm() {
    document.getElementById('username').value = '';
    document.getElementById('password').value = '';
}

function loadProjectsFromBackend() {
    fetch('http://localhost/backend.php', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ action: 'get_projects' })
    })
    .then(response => response.json())
    .then(projects => {
        const projectsRow = document.querySelector('.row2');
        projectsRow.innerHTML = '';

        projects.forEach(project => {
            const projectElement = createProjectElement(project.title, project.description, project.youtubeLink);
            projectElement.dataset.id = project.id;
            projectsRow.appendChild(projectElement);
        });
    })
    .catch(error => {
        console.error('Error:', error);
    });
}

function toggleProjectButtons(show) {
    const projectElements = document.querySelectorAll('.row2 .icon-box');
    projectElements.forEach(projectElement => {
        const deleteButton = projectElement.querySelector('.project-delete-btn');
        const updateButton = projectElement.querySelector('.project-update-btn');
        if (show) {
            deleteButton.style.display = 'inline-block';
            updateButton.style.display = 'inline-block';
        } else {
            deleteButton.style.display = 'none';
            updateButton.style.display = 'none';
        }
    });
}

document.addEventListener('DOMContentLoaded', loadProjectsFromBackend);

