// إضافة استماع لزر "Send Message"

document.addEventListener("DOMContentLoaded", function () {
const form = document.querySelector('.php-email-form');
const formActionLink = document.getElementById('form-action-link1');
const sentMessage = document.querySelector('.sent-message');
const loadingSpinner = document.querySelector('.loading-spinner');


// Update the form action when the input changes
if (formActionLink) {
    formActionLink.addEventListener('input', function () {
        const newAction = formActionLink.value.trim();
        if (newAction && !newAction.startsWith('file:///')) {
            form.action = newAction;
            localStorage.setItem('form-action', newAction);
        }
    });

    // Load the form action from localStorage on page load
    const storedAction = localStorage.getItem('form-action');
    if (storedAction && !storedAction.startsWith('file:///')) {
        form.action = storedAction;
        formActionLink.value = storedAction;
    }
}

document.querySelector('.btn-submit').addEventListener('click', (event) => {
    event.preventDefault();

    const emailInput = document.querySelector('input[name="email"]');
    if (!emailInput || emailInput.value.trim() === '') {
        alert('أضف الحساب رجاءً');
        return;
    }

    // نظام بسيط لمكافحة الرسائل المزعجة
    const antiSpamInput = document.querySelector('input[name="anti-spam"]');
    if (antiSpamInput && antiSpamInput.value.trim() !== '') {
        alert('The Spam threat has been detected. Please confirm the information');
        return;
    }

    const formAction = formActionLink.value.trim();
    if (formAction && formAction !== '111') {
        loadingSpinner.style.display = 'block';

        const formData = new FormData(form);

        fetch(formAction, {
            method: 'POST',
            body: formData,
            headers: {
                'Accept': 'application/json'
            }
        })
        .then(response => {
            if (response.ok) {
                form.reset();
                loadingSpinner.style.display = 'none';
                document.querySelector('.btn-submit').style.display = 'none';
                sentMessage.style.display = 'block';
                sentMessage.style.opacity = '1';

                setTimeout(() => {
                    sentMessage.style.transition = 'opacity 0.5s ease';
                    sentMessage.style.opacity = '0';

                    setTimeout(() => {
                        sentMessage.style.display = 'none';
                        window.location.href = 'index.html';
                    }, 500);
                }, 2500);
            } else {
               alert('Enter Your email')
            }
        })
        .catch(error => {
            console.error('حدث خطأ:', error);
        })
        .finally(() => {
            setTimeout(() => {
                loadingSpinner.style.display = 'none';
            }, 2000);
        });
    } else {
        alert('Please provide a valid form action URL.');
    }
});
});

